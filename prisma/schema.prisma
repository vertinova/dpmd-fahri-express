generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model activity_logs {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id     BigInt    @db.UnsignedBigInt
  user_name   String?   @db.VarChar(255)
  user_role   String?   @db.VarChar(50)
  bidang_id   BigInt?   @db.UnsignedBigInt
  module      String    @db.VarChar(50)
  action      String    @db.VarChar(50)
  entity_type String    @db.VarChar(100)
  entity_id   BigInt?   @db.UnsignedBigInt
  entity_name String?   @db.VarChar(255)
  description String    @db.Text
  old_value   Json?
  new_value   Json?
  ip_address  String?   @db.VarChar(45)
  user_agent  String?   @db.VarChar(500)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "activity_logs_user_id_foreign")

  @@index([action], map: "idx_action")
  @@index([bidang_id], map: "idx_bidang_id")
  @@index([created_at], map: "idx_created_at")
  @@index([module], map: "idx_module")
  @@index([module, action], map: "idx_module_action")
  @@index([user_id], map: "idx_user_id")
}

model aparatur_desa {
  id                         String                      @id @db.Char(36)
  desa_id                    BigInt                      @db.UnsignedBigInt
  nama_lengkap               String                      @db.VarChar(255)
  jabatan                    String                      @db.VarChar(255)
  nipd                       String?                     @db.VarChar(255)
  niap                       String?                     @db.VarChar(255)
  tempat_lahir               String                      @db.VarChar(255)
  tanggal_lahir              DateTime                    @db.Date
  jenis_kelamin              aparatur_desa_jenis_kelamin
  pendidikan_terakhir        String                      @db.VarChar(255)
  agama                      String                      @db.VarChar(255)
  pangkat_golongan           String?                     @db.VarChar(255)
  tanggal_pengangkatan       DateTime                    @db.Date
  nomor_sk_pengangkatan      String                      @db.VarChar(255)
  tanggal_pemberhentian      DateTime?                   @db.Date
  nomor_sk_pemberhentian     String?                     @db.VarChar(255)
  keterangan                 String?                     @db.VarChar(255)
  status                     aparatur_desa_status        @default(Aktif)
  produk_hukum_id            String?                     @db.Char(36)
  bpjs_kesehatan_nomor       String?                     @db.VarChar(255)
  bpjs_ketenagakerjaan_nomor String?                     @db.VarChar(255)
  file_bpjs_kesehatan        String?                     @db.VarChar(255)
  file_bpjs_ketenagakerjaan  String?                     @db.VarChar(255)
  file_pas_foto              String?                     @db.VarChar(255)
  file_ktp                   String?                     @db.VarChar(255)
  file_kk                    String?                     @db.VarChar(255)
  file_akta_kelahiran        String?                     @db.VarChar(255)
  file_ijazah_terakhir       String?                     @db.VarChar(255)
  created_at                 DateTime?                   @db.Timestamp(0)
  updated_at                 DateTime?                   @db.Timestamp(0)
  desas                      desas                       @relation(fields: [desa_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "aparatur_desa_desa_id_foreign")
  produk_hukums              produk_hukums?              @relation(fields: [produk_hukum_id], references: [id], onUpdate: NoAction, map: "aparatur_desa_produk_hukum_id_foreign")

  @@index([desa_id], map: "aparatur_desa_desa_id_foreign")
  @@index([produk_hukum_id], map: "aparatur_desa_produk_hukum_id_foreign")
}

model app_settings {
  id                 Int       @id @default(autoincrement())
  setting_key        String    @unique @db.VarChar(100)
  setting_value      String    @db.Text
  description        String?   @db.VarChar(255)
  updated_by_user_id BigInt?   @db.UnsignedBigInt
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
  users              users?    @relation(fields: [updated_by_user_id], references: [id], map: "fk_app_settings_user")

  @@index([updated_by_user_id], map: "fk_app_settings_user_idx")
  @@index([setting_key], map: "idx_setting_key")
}

model bankeu_master_kegiatan {
  id                       Int                                   @id @default(autoincrement()) @db.UnsignedTinyInt
  jenis_kegiatan           bankeu_master_kegiatan_jenis_kegiatan
  urutan                   Int                                   @db.UnsignedTinyInt
  nama_kegiatan            String                                @db.Text
  dinas_terkait            String?                               @db.VarChar(255)
  is_active                Boolean?                              @default(true)
  created_at               DateTime?                             @default(now()) @db.Timestamp(0)
  bankeu_proposal_kegiatan bankeu_proposal_kegiatan[]
  berita_acara_history     berita_acara_history[]

  @@index([dinas_terkait], map: "idx_dinas_terkait")
  @@index([jenis_kegiatan], map: "idx_jenis")
}

model bankeu_proposal_kegiatan {
  id                     BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  proposal_id            BigInt                 @db.UnsignedBigInt
  kegiatan_id            Int                    @db.UnsignedTinyInt
  created_at             DateTime?              @default(now()) @db.Timestamp(0)
  bankeu_master_kegiatan bankeu_master_kegiatan @relation(fields: [kegiatan_id], references: [id], onDelete: Cascade, map: "fk_proposal_kegiatan_kegiatan")
  bankeu_proposals       bankeu_proposals       @relation(fields: [proposal_id], references: [id], onDelete: Cascade, map: "fk_proposal_kegiatan_proposal")

  @@unique([proposal_id, kegiatan_id], map: "unique_proposal_kegiatan")
  @@index([kegiatan_id], map: "idx_kegiatan_id")
  @@index([proposal_id], map: "idx_proposal_id")
}

model bankeu_proposals {
  id                                                  BigInt                               @id @default(autoincrement()) @db.UnsignedBigInt
  desa_id                                             BigInt                               @db.UnsignedBigInt
  tahun_anggaran                                      Int                                  @default(2026) @db.Year
  kegiatan_id                                         Int?                                 @db.UnsignedTinyInt
  judul_proposal                                      String                               @db.VarChar(255)
  nama_kegiatan_spesifik                              String?                              @db.VarChar(255)
  volume                                              String?                              @db.VarChar(255)
  lokasi                                              String?                              @db.VarChar(255)
  deskripsi                                           String?                              @db.Text
  file_proposal                                       String                               @db.VarChar(255)
  surat_pengantar                                     String?                              @db.VarChar(255)
  surat_permohonan                                    String?                              @db.VarChar(255)
  dinas_reviewed_file                                 String?                              @db.VarChar(255)
  dinas_reviewed_at                                   DateTime?                            @db.Timestamp(0)
  file_size                                           Int?                                 @db.UnsignedInt
  anggaran_usulan                                     Decimal?                             @db.Decimal(15, 2)
  status                                              bankeu_proposals_status?             @default(pending)
  dinas_status                                        bankeu_proposals_dinas_status?
  submitted_to_dinas_at                               DateTime?                            @db.Timestamp(0)
  dinas_verified_at                                   DateTime?                            @db.Timestamp(0)
  dinas_verified_by                                   Int?
  dinas_catatan                                       String?                              @db.Text
  kecamatan_status                                    bankeu_proposals_kecamatan_status?
  kecamatan_verified_at                               DateTime?                            @db.Timestamp(0)
  kecamatan_verified_by                               BigInt?                              @db.UnsignedBigInt
  kecamatan_catatan                                   String?                              @db.Text
  dpmd_status                                         bankeu_proposals_dpmd_status?
  dpmd_verified_at                                    DateTime?                            @db.Timestamp(0)
  dpmd_verified_by                                    BigInt?                              @db.UnsignedBigInt
  dpmd_catatan                                        String?                              @db.Text
  submitted_to_kecamatan                              Boolean?                             @default(false)
  submitted_at                                        DateTime?                            @db.Timestamp(0)
  submitted_to_dpmd                                   Boolean?                             @default(false)
  submitted_to_dpmd_at                                DateTime?                            @db.Timestamp(0)
  catatan_verifikasi                                  String?                              @db.Text
  verified_by                                         BigInt?                              @db.UnsignedBigInt
  verified_at                                         DateTime?                            @db.Timestamp(0)
  berita_acara_path                                   String?                              @db.VarChar(255)
  berita_acara_generated_at                           DateTime?                            @db.Timestamp(0)
  created_by                                          BigInt                               @db.UnsignedBigInt
  created_at                                          DateTime?                            @default(now()) @db.Timestamp(0)
  updated_at                                          DateTime?                            @default(now()) @db.Timestamp(0)
  troubleshoot_at                                     DateTime?                            @db.Timestamp(0)
  troubleshoot_by                                     BigInt?                              @db.UnsignedBigInt
  troubleshoot_catatan                                String?                              @db.Text
  bankeu_proposal_kegiatan                            bankeu_proposal_kegiatan[]
  users_bankeu_proposals_dpmd_verified_byTousers      users?                               @relation("bankeu_proposals_dpmd_verified_byTousers", fields: [dpmd_verified_by], references: [id], onUpdate: NoAction, map: "fk_bankeu_dpmd_verified_by")
  users_bankeu_proposals_kecamatan_verified_byTousers users?                               @relation("bankeu_proposals_kecamatan_verified_byTousers", fields: [kecamatan_verified_by], references: [id], onUpdate: NoAction, map: "fk_bankeu_kecamatan_verified_by")
  users_bankeu_proposals_created_byTousers            users                                @relation("bankeu_proposals_created_byTousers", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bankeu_proposals_created_by")
  desas                                               desas                                @relation(fields: [desa_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bankeu_proposals_desa")
  users_bankeu_proposals_verified_byTousers           users?                               @relation("bankeu_proposals_verified_byTousers", fields: [verified_by], references: [id], onUpdate: NoAction, map: "fk_bankeu_proposals_verified_by")
  users_bankeu_proposals_troubleshoot_byTousers       users?                               @relation("bankeu_proposals_troubleshoot_byTousers", fields: [troubleshoot_by], references: [id], onUpdate: NoAction, map: "fk_bankeu_troubleshoot_by")
  bankeu_verification_questionnaires                  bankeu_verification_questionnaires[]
  berita_acara_history                                berita_acara_history[]

  @@index([created_by], map: "idx_created_by")
  @@index([desa_id], map: "idx_desa")
  @@index([dinas_status], map: "idx_dinas_status")
  @@index([dinas_verified_by], map: "idx_dinas_verified_by")
  @@index([dpmd_status], map: "idx_dpmd_status")
  @@index([dpmd_verified_by], map: "idx_dpmd_verified_by")
  @@index([kecamatan_status], map: "idx_kecamatan_status")
  @@index([kecamatan_verified_by], map: "idx_kecamatan_verified_by")
  @@index([status], map: "idx_status")
  @@index([submitted_to_dpmd], map: "idx_submitted_to_dpmd")
  @@index([submitted_to_kecamatan], map: "idx_submitted_to_kecamatan")
  @@index([troubleshoot_by], map: "idx_troubleshoot_by")
  @@index([verified_by], map: "idx_verified_by")
}

model bankeu_verification_questionnaires {
  id                       BigInt                                                     @id @default(autoincrement()) @db.UnsignedBigInt
  proposal_id              BigInt                                                     @db.UnsignedBigInt
  tim_verifikasi_id        BigInt?                                                    @db.UnsignedBigInt
  verifikasi_type          bankeu_verification_questionnaires_verifikasi_type?        @default(kecamatan)
  dinas_id                 Int?
  q1                       Boolean?
  q2                       Boolean?
  q3                       Boolean?
  q4                       Boolean?
  q5                       Boolean?
  q6                       Boolean?
  q7                       Boolean?
  q8                       Boolean?
  q9                       Boolean?
  q10                      Boolean?
  q11                      Boolean?
  q12                      Boolean?
  q13                      Boolean?
