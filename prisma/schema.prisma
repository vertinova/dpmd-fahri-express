model desa_bankeu_surat {
  id                     BigInt                              @id @default(autoincrement()) @db.UnsignedBigInt
  desa_id                BigInt                              @db.UnsignedBigInt
  tahun                  Int                                 @default(2025) @db.Year
  surat_pengantar        String?                             @db.VarChar(255)
  surat_permohonan       String?                             @db.VarChar(255)
  submitted_to_kecamatan Boolean                             @default(false)
  submitted_at           DateTime?                           @db.Timestamp(0)
  kecamatan_status       desa_bankeu_surat_kecamatan_status? @default(pending)
  kecamatan_reviewed_by  BigInt?                             @db.UnsignedBigInt
  kecamatan_reviewed_at  DateTime?                           @db.Timestamp(0)
  kecamatan_catatan      String?                             @db.Text
  created_at             DateTime?                           @default(now()) @db.Timestamp(0)
  updated_at             DateTime?                           @default(now()) @db.Timestamp(0)
  desas                  desas                               @relation(fields: [desa_id], references: [id], onDelete: Cascade, map: "fk_desa_bankeu_surat_desa")
