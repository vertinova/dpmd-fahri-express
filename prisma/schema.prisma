  master_dinas             master_dinas?                                              @relation(fields: [dinas_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_questionnaire_dinas")
  bankeu_proposals         bankeu_proposals                                           @relation(fields: [proposal_id], references: [id], onDelete: Cascade, map: "fk_questionnaire_proposal")
