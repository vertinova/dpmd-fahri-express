  q2_keterangan            String?                                                    @db.Text
  q3_keterangan            String?                                                    @db.Text
  q4_keterangan            String?                                                    @db.Text
  q5_keterangan            String?                                                    @db.Text
  q6_keterangan            String?                                                    @db.Text
  q7_keterangan            String?                                                    @db.Text
  q8_keterangan            String?                                                    @db.Text
  q9_keterangan            String?                                                    @db.Text
  q10_keterangan           String?                                                    @db.Text
  q11_keterangan           String?                                                    @db.Text
